#!/bin/bash
# Pre-commit hook: проверяет код перед коммитом.
# Запускает verify_contract.py на последнем собранном APK.
#
# Установка:
#   git config core.hooksPath .githooks

set -e

echo "🔍 Pre-commit: запуск верификации контракта roadmap..."

# Найти JDK — использовать JAVA_HOME из окружения
if [ -z "$JAVA_HOME" ]; then
    echo "⚠️  JAVA_HOME не установлен. Пытаемся найти JDK через PATH..."
    if command -v java &> /dev/null; then
        JAVA_HOME=$(dirname "$(dirname "$(readlink -f "$(which java)")")")
        export JAVA_HOME
        export PATH="$JAVA_HOME/bin:$PATH"
    else
        echo "⚠️  Java не найдена в PATH — возможны ошибки сборки"
    fi
else
    export PATH="$JAVA_HOME/bin:$PATH"
fi

APK="app/build/outputs/apk/debug/app-debug.apk"
SCRIPT="scripts/verify_contract.py"

if [ -f "$APK" ] && [ -f "$SCRIPT" ]; then
    python3 "$SCRIPT" --apk "$APK" || {
        echo "❌ Pre-commit: верификация не пройдена. Коммит отклонён."
        exit 1
    }
else
    echo "⚠️  APK не найден — пропускаем верификацию. Запустите ./gradlew assembleDebug"
fi
